# Required in production for durable accounts and activity.
DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MAX=10

# Required in production. Use at least 32 random characters.
NESTORA_SESSION_SECRET=

# Optional deployment origin, for example https://nestora.africa.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Temporary operational addresses. Replace all values when the domain mailbox is ready.
ADMIN_EMAIL=jonahbaka00@gmail.com
SUPPORT_EMAIL=jonahbaka00@gmail.com
CONTACT_EMAIL=jonahbaka00@gmail.com
EMAIL_FROM="Nestora <jonahbaka00@gmail.com>"
EMAIL_REPLY_TO=jonahbaka00@gmail.com

# Private media storage. Use an IAM identity limited to this bucket prefix.
NESTORA_STORAGE_BUCKET=
NESTORA_STORAGE_ENDPOINT=
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Required in production. The scanner must return JSON with { "clean": true }.
NESTORA_MALWARE_SCAN_URL=
NESTORA_MALWARE_SCAN_TOKEN=

# External email/SMS/push adapter and protected queue worker.
NESTORA_DELIVERY_WEBHOOK_URL=
NESTORA_DELIVERY_WEBHOOK_TOKEN=
NESTORA_JOB_SECRET=

# Staging/deployed end-to-end checks. Do not commit real credentials.
NESTORA_E2E_BASE_URL=
NESTORA_E2E_PASSWORD=
NESTORA_E2E_ENVIRONMENT=staging
